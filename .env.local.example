# Sanity CMS
# Lấy Project ID tại: https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Thông tin liên hệ
NEXT_PUBLIC_ZALO_NUMBER=0972916382

# URL website (dùng cho sitemap và OG tags)
NEXT_PUBLIC_SITE_URL=https://httech.vn

# Gmail SMTP — gửi email khi có yêu cầu liên hệ từ website
# Hướng dẫn lấy App Password: myaccount.google.com/apppasswords
# (cần bật 2-Step Verification trước)
GMAIL_USER=Httechbn@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Gemini API Key cho Trợ lý ảo AI
# Lấy API Key miễn phí tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
